        "jsCode": "const jobs = $json.rss.channel.item;\n\nreturn jobs.map(j => ({\n  json: {\n    title: j.title,\n    company: j.title.split(\":\")[0],\n    location: \"Remote\",\n    url: j.link,\n    source: \"weworkremotely\"\n  }\n}));"
